      "parameters": {
        "jsCode": "return items.map(item => {\n  const url = item.json.resume_link;\n\n  const match = url.match(/[-\\w]{25,}/);\n\n  item.json.file_id = match ? match[0] : null;\n\n  return item;\n});"
