      "parameters": {
        "promptType": "define",
        "text": "=Write a reply to this meeting request. If thhe requested slot is free then create the email accordingly, else if the requested slot is not available then create an email something like this:\nHi {{ JSON.parse($('Route by Classification').item.json.text).sender_name }},\n\nThank you for your interest! \n\nI have checked my calendar, and unfortunately, I am already booked during the time you requested ({{ JSON.parse($('Route by Classification').item.json.text).proposed_meeting_times[0] }}). \n\nWould you be open to meeting tomorrow at this same time instead? \n\nPlease let me know if this works for you, or feel free to suggest another slot.\n\nSender name: {{ JSON.parse($('Route by Classification').item.json.text).sender_name ?? 'the sender' }}\nSummary: {{ JSON.parse($('Route by Classification').item.json.text).summary }}\nStated need: {{ JSON.parse($('Route by Classification').item.json.text).stated_need }}\nProposed times: {{ JSON.parse($('Route by Classification').item.json.text).proposed_meeting_times.length > 0 ? JSON.parse($('Route by Classification').item.json.text).proposed_meeting_times.join(', ') : 'none provided' }}\nCalendar slot free: {{ $('Is Slot Free?').item.json.available ?? 'unknown' }}",
        "messages": {
          "messageValues": [
            {
              "message": "You are a professional email assistant. Write a concise, warm, and professional reply to a meeting request email.\n\nRules:\n- Address the sender by first name only\n- If proposed_meeting_times has values, confirm the first one and mention a video call link will follow\n- If proposed_meeting_times is empty, politely ask the sender to suggest available times\n- Keep the reply under 100 words\n- Do NOT include a subject line, sign-off name, or any placeholders like [Your Name]\n- End with: 'Looking forward to speaking with you.'\n- Output ONLY the email body text, nothing else"
            }
          ]
        },
        "batching": {}
      },
