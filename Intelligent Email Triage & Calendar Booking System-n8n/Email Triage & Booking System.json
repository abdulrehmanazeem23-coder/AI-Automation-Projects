      "parameters": {
        "jsonSchemaExample": "{\n  \"classification\": \"New Client Enquiry\",\n  \"sender_name\": \"John Smith\",\n  \"company\": \"Acme Corp\",\n  \"stated_need\": \"The sender wants a product demo.\",\n  \"urgency_score\": 3,\n  \"proposed_meeting_times\": [],\n  \"summary\": \"John from Acme Corp wants a product demo for his team. No meeting times proposed.\"\n}",
        "autoFix": true
