                    "operator": {
                      "operation": "equals",
                      "type": "string"
                    },
                    "rightValue": "New Client Enquiry"
                  }
                ],
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "loose",
                  "version": 2
                }
              },
              "renameOutput": true,
