                      "type": "string"
                    },
                    "rightValue": "Urgent Escalation"
                  }
                ],
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "loose",
                  "version": 2
                }
              },
              "renameOutput": true,
              "outputKey": "Urgent Escalation"
